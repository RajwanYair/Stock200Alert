{
  "name": "crosstide",
  "version": "6.5.0",
  "description": "CrossTide Web — browser-based stock monitoring dashboard with 12-method consensus signals, interactive charting, and offline-first PWA.",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/RajwanYair/CrossTide",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RajwanYair/CrossTide.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && tsc --project tsconfig.sw.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:css": "stylelint \"src/**/*.css\" --max-warnings 0",
    "lint:html": "htmlhint index.html",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\" \"#coverage\" \"#build\" \"#docs/ROADMAP.archive*\"",
    "lint:all": "npm run lint && npm run lint:css && npm run lint:html && npm run lint:md && npm run format:check",
    "format": "prettier --write \"**/*.{ts,md,json,css,html,mjs}\" \"!dist/**\" \"!coverage/**\" \"!build/**\" \"!node_modules/**\" \"!docs/ROADMAP.archive*\"",
    "format:check": "prettier --check \"**/*.{ts,md,json,css,html,mjs}\" \"!dist/**\" \"!coverage/**\" \"!build/**\" \"!node_modules/**\" \"!docs/ROADMAP.archive*\"",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.sw.json --noEmit",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "ci": "npm run typecheck && npm run lint:all && npm run test:coverage && npm run build && npm run check:bundle",
    "clean": "node scripts/clean.mjs"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "happy-dom": "^20.9.0",
    "htmlhint": "^1.9.2",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.7.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "lightweight-charts": "^5.2.0",
    "valibot": "^1.3.1",
    "zod": "^4.4.1"
  }
}
