{
  "name": "crosstide",
  "version": "7.26.0",
  "description": "CrossTide Web — browser-based stock monitoring dashboard with 12-method consensus signals, interactive charting, and offline-first PWA.",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/main.ts",
    "./core": "./src/core/index.ts",
    "./domain": "./src/domain/index.ts",
    "./cards": "./src/cards/index.ts",
    "./ui": "./src/ui/index.ts"
  },
  "homepage": "https://github.com/RajwanYair/CrossTide",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RajwanYair/CrossTide.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "vite",
    "dev:components": "vite docs/components-preview.html",
    "build": "tsc --noEmit && tsc --project tsconfig.sw.json --noEmit && vite build && node scripts/workbox-inject.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "lhci": "lhci autorun --config config/lighthouserc.json",
    "lint": "eslint . --max-warnings 0",
    "lint:css": "stylelint \"src/**/*.css\" --config config/.stylelintrc.json --max-warnings 0",
    "lint:html": "htmlhint index.html --config config/.htmlhintrc",
    "lint:md": "markdownlint-cli2 --config config/.markdownlint.json \"**/*.md\" \"#**/node_modules/**\" \"#dist\" \"#coverage\" \"#build\" \"#test-results\" \"#playwright-report\" \"#docs/ROADMAP.archive*\"",
    "lint:all": "npm run lint && npm run lint:css && npm run lint:html && npm run lint:md && npm run format:check",
    "format": "prettier --write \"**/*.{ts,md,json,css,html,mjs}\" \"!dist/**\" \"!coverage/**\" \"!build/**\" \"!node_modules/**\" \"!test-results/**\" \"!playwright-report/**\" \"!docs/ROADMAP.archive*\"",
    "format:check": "prettier --check \"**/*.{ts,md,json,css,html,mjs}\" \"!dist/**\" \"!coverage/**\" \"!build/**\" \"!node_modules/**\" \"!test-results/**\" \"!playwright-report/**\" \"!docs/ROADMAP.archive*\"",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.sw.json --noEmit",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check:supply-chain": "npm audit --omit=dev --audit-level=high && npm audit signatures",
    "ci": "npm run typecheck && npm run lint:all && npm run test:coverage && npm run build && npm run check:bundle",
    "clean": "node scripts/clean.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "commit-msg": "npx commitlint --config config/commitlint.config.mjs --edit $1",
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,mjs}": [
      "eslint --max-warnings 0 --no-warn-ignored --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --config config/.stylelintrc.json --max-warnings 0 --fix",
      "prettier --write"
    ],
    "*.{md,json,html}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Edge versions",
    "last 2 Safari versions",
    "last 2 Firefox versions",
    "last 2 Opera versions",
    "last 2 Samsung Internet versions",
    "last 2 ChromeAndroid versions",
    "last 2 FirefoxAndroid versions",
    "iOS >= 16.4",
    "not dead"
  ],
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.59.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-plugin-import-x": "^4.16.2",
    "happy-dom": "^20.9.0",
    "htmlhint": "^1.9.2",
    "https-proxy-agent": "^9.0.0",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.4",
    "workbox-background-sync": "^7.4.0",
    "workbox-build": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-navigation-preload": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@js-temporal/polyfill": "^0.5.1",
    "hono": "^4.12.16",
    "lightweight-charts": "^5.2.0",
    "valibot": "^1.3.1"
  }
}
