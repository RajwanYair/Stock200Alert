{
  "name": "crosstide",
  "version": "6.0.0",
  "description": "CrossTide Web — Browser-based stock monitoring dashboard with 12-method consensus signals, interactive charting, and offline-first PWA.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:css": "stylelint \"src/**/*.css\" --max-warnings 0",
    "lint:html": "htmlhint index.html",
    "lint:md": "markdownlint-cli2 \"*.md\" \"docs/**/*.md\" \".github/**/*.md\"",
    "lint:all": "npm run lint && npm run lint:css && npm run lint:html && npm run lint:md",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "ci": "npm run typecheck && npm run lint:all && npm run test:coverage && npm run build && npm run check:bundle",
    "clean": "node -e \"const fs=require('fs');['dist','coverage'].forEach(d=>{fs.rmSync(d,{recursive:true,force:true})})\""
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  }
}
