{
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "description": "Auto-format Dart files after edits",
        "matcher": "edit|create_file",
        "windows": "powershell -NoProfile -Command \"dart format --fix $TOOL_INPUT_FILE 2>$null; exit 0\"",
        "linux": "dart format --fix \"$TOOL_INPUT_FILE\" 2>/dev/null || true",
        "timeout": 10
      }
    ]
  }
}
